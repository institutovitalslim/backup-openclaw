# Copy to: /root/.openclaw/workspace/ops/zapi_bridge/zapi_bridge.env
# Fill with real values before enabling the service.

BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787
HTTP_TIMEOUT_SECONDS=90
DEDUP_TTL_SECONDS=600

OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/v1/responses
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME
OPENCLAW_AGENT_REF=openclaw/main
OPENCLAW_MODEL_OVERRIDE=openai/gpt-5.4
OPENCLAW_SESSION_PREFIX=bridge:zapi

# Prefer full base URL if you already know it.
# Example: https://api.z-api.io/instances/<instance>/token/<token>
ZAPI_BASE_URL=
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_SEND_TEXT_PATH=/send-text

APPS_SCRIPT_FANOUT_URL=
BRIDGE_SHARED_SECRET=
